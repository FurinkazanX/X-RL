# 忽略 Python 编译生成的文件
__pycache__/
*.py[cod]
*$py.class

# 忽略虚拟环境
venv/
env/
*.env

# 忽略 IDE 相关文件
.idea/
.vscode/
*.swp
*.swo
*~

# 忽略日志文件
logs/
*.log

# 忽略数据文件
data/
datasets/

# 忽略模型文件
models/
checkpoints/

# 忽略临时文件
temp/
tmp/
*.tmp
*.temp

# 忽略构建文件
build/
dist/
*.egg-info/

# 忽略系统文件
.DS_Store
Thumbs.db

# 忽略配置文件（如果包含敏感信息）
# configs/*.yaml

# 忽略测试输出
pytest_cache/

# 忽略覆盖文件
.coverage
coverage.xml

# 忽略 Docker 相关文件
Dockerfile
.dockerignore

# 忽略 Ray 相关文件
ray_results/
/tmp/ray/
